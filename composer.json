{
    "name": "maxlcoder/laravel-oss",
    "description": "阿里云 OSS Laravel 扩展",
    "type": "library",
    "require": {
        "php": "^7.3|^8.0",
        "illuminate/support": "^9.0|^10.0|^11.0",
        "alibabacloud/oss-v2": "^0.4.0",
        "alibabacloud/credentials": "^1.2"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Maxlcoder\\LaravelOss\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maxlcoder\\LaravelOss\\OssServiceProvider"
            ],
            "aliases": {
                "Oss": "Maxlcoder\\LaravelOss\\Oss"
            }
        }
    }
}
